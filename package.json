{
  "name": "trade-journal",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "npm --prefix client run dev",
    "build": "npm --prefix client install && npm --prefix client run build",
    "start": "NODE_ENV=production node --experimental-sqlite server/index.js",
    "install:all": "npm install && npm --prefix client install"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
